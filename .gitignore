# =============================================================================
# Accetraa Technologies — .gitignore
# Production-grade exclusions for a Django + React monorepo.
# Covers: Python, Django, Node, VS Code, JetBrains, macOS, Windows, AWS.
# =============================================================================


# =============================================================================
# SECRETS & ENVIRONMENT — never commit real credentials
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.cer
secrets/
credentials/
*_credentials.json
service-account*.json


# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
*.so

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST
sdist/

# Unit test / coverage
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
test-results/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/


# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/


# =============================================================================
# DJANGO
# =============================================================================
# SQLite dev database
db.sqlite3
db.sqlite3-journal

# Collected static files (generated by collectstatic — never commit)
staticfiles/
static_root/

# Media uploads (user-uploaded files — served from S3 in production)
media/

# Django local cache
*.cache


# =============================================================================
# NODE / FRONTEND
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output (frontend)
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# Vite cache
.vite/
frontend/.vite/

# Package manager lock files — include one, exclude others to avoid conflicts
# (keep whichever your project uses; remove the other lines)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# =============================================================================
# VS CODE
# =============================================================================
.vscode/
!.vscode/extensions.json  # keep recommended extensions list if present
*.code-workspace


# =============================================================================
# JETBRAINS IDEs (PyCharm, WebStorm, IntelliJ)
# =============================================================================
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/


# =============================================================================
# MACOS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?


# =============================================================================
# WINDOWS
# =============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
log/
pip-log.txt


# =============================================================================
# AWS — local credential files (must never be committed)
# =============================================================================
.aws/
aws-credentials
aws_credentials
*_access_key*
*_secret_key*


# =============================================================================
# DOCKER (future use)
# =============================================================================
.dockerignore.local
docker-compose.override.yml
docker-compose.local.yml


# =============================================================================
# CLAUDE CODE (AI assistant project settings — machine-local)
# =============================================================================
.claude/


# =============================================================================
# MISC
# =============================================================================
*.bak
*.swp
*.swo
*~
.history/
.hypothesis/
